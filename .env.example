# Copy to .env and fill in your real key.
# .env is git-ignored so the real key never gets committed.
#
# Inside the Udacity / Vocareum cloud workspace use the course-issued
# voc-... key. Locally you can use a regular sk-... OpenAI key — set
# OPENAI_API_BASE=https://api.openai.com/v1 to bypass the Vocareum proxy.
OPENAI_API_KEY=voc-...
OPENAI_API_BASE=https://openai.vocareum.com/v1
